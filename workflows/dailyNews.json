    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst raw = $('AI MODEL').item.json.choices[0].message.content;\n\n// Convert markdown to HTML\nconst html = raw\n  .replace(/\\*\\*(.*?)\\*\\*/g, '<b>$1</b>')\n  .replace(/\\n\\n/g, '</p><p>')\n  .replace(/\\n/g, '<br/>');\n\nconst emailBody = `\n<html>\n<body style=\"font-family: Arial, sans-serif; max-width: 650px; margin: 0 auto; padding: 20px; color: #333;\">\n  \n  <div style=\"background: linear-gradient(135deg, #1A237E, #1565C0); padding: 24px; border-radius: 10px; text-align: center; margin-bottom: 24px;\">\n    <h1 style=\"color: white; margin: 0; font-size: 24px;\">🤖 Daily AI News Digest</h1>\n    <p style=\"color: #BBDEFB; margin: 8px 0 0 0; font-size: 14px;\">${new Date().toDateString()}</p>\n  </div>\n\n\n\n  <p>${html}</p>\n\n  <hr style=\"border: none; border-top: 1px solid #eee; margin: 24px 0;\"/>\n  <p style=\"color: #999; font-size: 11px; text-align: center;\">\n    Sent automatically by your n8n AI News Bot 🤖<br/>\n    Built by Sandeep Choudhary\n  </p>\n\n</body>\n</html>\n`;\n\nreturn [{ json: { emailBody } }];;"
      },
